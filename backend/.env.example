# Copiá este archivo a ".env" y completá con tus datos reales.
# El archivo ".env" NUNCA se sube a git (ya está en .gitignore).

# Connection string de MongoDB Atlas (Database > Connect > Drivers > Node.js)
# Reemplazá <password> por la contraseña real del usuario de base de datos.
MONGODB_URI=mongodb+srv://usuario:password@finca-santa-fe.xxxxx.mongodb.net/finca-santa-fe?appName=finca-santa-fe

# Puerto donde corre el servidor localmente
PORT=4000

# Orígenes permitidos para CORS (separados por coma).
# En desarrollo local, el sitio se abre como archivo (file://) o con
# un servidor simple en localhost — ajustá según corresponda.
CORS_ORIGIN=http://localhost:5500,http://127.0.0.1:5500
